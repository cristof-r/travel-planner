{
    "compilerOptions": {
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2018",
        "allowJs": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "lib": [
            "DOM",
            "ES2018",
            "ES2021.String"
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}
